{
  "expo": {
    "name": "Cicla Vera",
    "slug": "cicla-vera",
    "scheme": "cicla-vera",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF7F2"
    },
    "ios": {
      "config": {
        "usesNonExemptEncryption": false
      },
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF7F2"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Permitir que o Cicla Vera acesse sua biometria."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir que o Cicla Vera use sua biometria para desbloquear areas protegidas."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permitir que o Cicla Vera use sua localizacao enquanto o app esta aberto.",
          "locationAlwaysAndWhenInUsePermission": "Permitir que o Cicla Vera use sua localizacao para lembretes e recursos de seguranca configurados por voce.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o Cicla Vera use a camera quando voce iniciar uma captura.",
          "microphonePermission": "Permitir que o Cicla Vera use o microfone quando voce iniciar uma gravacao.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Permitir que o Cicla Vera use o microfone quando voce iniciar uma gravacao.",
          "recordAudioAndroid": true,
          "enableBackgroundRecording": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#F2617E",
          "defaultChannel": "cycle-care"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
