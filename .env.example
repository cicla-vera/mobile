# Backend API base URLs used by the mobile app.
#
# Resolution order:
# 1. platform-specific URL below
# 2. EXPO_PUBLIC_API_URL fallback for all platforms
# 3. built-in local defaults
#
# Web runs in the browser on your computer.
EXPO_PUBLIC_API_URL_WEB=http://localhost:3001/api
#
# Android emulator/BlueStacks uses 10.0.2.2 to reach the Windows host.
EXPO_PUBLIC_API_URL_ANDROID=http://10.0.2.2:3001/api
#
# Physical iPhone needs the LAN IP of the machine exposing the backend.
EXPO_PUBLIC_API_URL_IOS=http://YOUR_COMPUTER_LAN_IP:3001/api
#
# Optional legacy/global fallback. Leave empty when using platform-specific URLs.
EXPO_PUBLIC_API_URL=

# Safe Vera presentation mode. Leave empty for normal builds.
# Set exactly to safe-local-demo to use mock Vera data without backend writes.
EXPO_PUBLIC_VERA_DEMO_MODE=
